              Text('е…іжіЁ').fontSize(13).fontColor('rgba(255,255,255,0.7)')
            }.margin({ right: 30 })
            Column() {
              Text('256').fontSize(20).fontWeight(FontWeight.Bold).fontColor(Color.White)
              Text('зІүдёқ').fontSize(13).fontColor('rgba(255,255,255,0.7)')
            }.margin({ right: 30 })
            Column() {
              Text('89').fontSize(20).fontWeight(FontWeight.Bold).fontColor(Color.White)
              Text('иҺ·иөһ').fontSize(13).fontColor('rgba(255,255,255,0.7)')
            }
          }
